FROM eclipse-temurin:25-jdk

ARG UID=1000
ARG GID=1000
ARG http_proxy
ARG https_proxy

RUN export http_proxy="${http_proxy:-}" https_proxy="${https_proxy:-}" \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        git \
        findutils \
        unzip \
        wget \
    && rm -rf /var/lib/apt/lists/* \
    && wget -q https://github.com/JetBrains/kotlin/releases/download/v2.4.0/kotlin-compiler-2.4.0.zip -O /tmp/kotlin.zip \
    && unzip -q /tmp/kotlin.zip -d /opt/ \
    && rm /tmp/kotlin.zip \
    && ln -sf /opt/kotlinc/bin/kotlinc /usr/local/bin/kotlinc \
    && apt-get purge -y unzip wget \
    && apt-get autoremove -y \
    && mkdir -p /gradle-cache /home/user/.m2 \
    && chown -R $UID:$GID /gradle-cache /home/user

ENV GRADLE_USER_HOME=/gradle-cache
ENV HOME=/home/user

USER $UID:$GID

WORKDIR /workspace
