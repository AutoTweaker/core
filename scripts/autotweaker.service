[Unit]
Description=AutoTweaker AI Agent
After=network-online.target

[Service]
Type=simple
EnvironmentFile=-%h/.config/autotweaker/env
ExecStart=/usr/libexec/autotweaker/autotweakerd
SuccessExitStatus=143
Restart=on-failure
RestartSec=5
StartLimitBurst=3
StartLimitInterval=60s

[Install]
WantedBy=default.target
