SOCK="${XDG_CONFIG_HOME:-$HOME/.config}/autotweaker/cli.sock"

systemctl --user daemon-reload 2>/dev/null || true
if ! systemctl --user is-active --quiet autotweaker 2>/dev/null; then
    echo "autotweaker: starting daemon..." >&2
    systemctl --user start autotweaker
    for _ in $(seq 1 150); do
        [ -S "$SOCK" ] && break
        sleep 0.1
    done
fi
[ ! -S "$SOCK" ] && { echo "autotweaker: failed to start daemon" >&2; exit 1; }

if [ -t 0 ]; then
    stdin=""
else
    stdin=$(cat)
fi
printf '{"args":%s,"stdin":%s}\n' \
    "$(printf '%s\n' "$@" | jq -R . | jq -s -c .)" \
    "$(printf '%s' "$stdin" | jq -Rs -c .)" \
    | socat - "UNIX-CONNECT:$SOCK"
