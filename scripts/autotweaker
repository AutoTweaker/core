CONF="${XDG_CONFIG_HOME:-$HOME/.config}/autotweaker"
SOCK="$CONF/cli.sock"
LOCK="$CONF/autotweaker.lock"

mkdir -p "$CONF"
for v in https_proxy HTTPS_PROXY http_proxy HTTP_PROXY all_proxy ALL_PROXY no_proxy NO_PROXY; do
    eval "val=\${$v:-}"
    [ -n "$val" ] && echo "$v=$val"
done > "$CONF/env"

systemctl --user daemon-reload 2>/dev/null || true

state=$(systemctl --user show autotweaker -p ActiveState --value 2>/dev/null)
if [ "$state" != "active" ]; then
    echo "Starting daemon..." >&2
    systemctl --user reset-failed autotweaker 2>/dev/null
    systemctl --user start autotweaker
fi

waited=0
while true; do
    if [ -S "$SOCK" ] && [ -f "$LOCK" ]; then
        break
    fi

    state=$(systemctl --user show autotweaker -p ActiveState --value 2>/dev/null)
    substate=$(systemctl --user show autotweaker -p SubState --value 2>/dev/null)
    case "$state:$substate" in
        failed:*|inactive:*|*:auto-restart)
            echo "Daemon failed to start, showing recent logs:" >&2
            journalctl --user -u autotweaker --no-pager -n 30 >&2
            exit 1
            ;;
    esac

    waited=$((waited + 1))
    if [ $waited -ge 300 ]; then
        echo "Daemon is taking too long, showing recent logs:" >&2
        journalctl --user -u autotweaker --no-pager -n 15 >&2
        waited=0
    fi
    sleep 0.1
done

if [ -t 0 ]; then
    stdin=""
else
    stdin=$(cat)
fi

request=$(printf '{"args":%s,"stdin":%s,"prog":"%s"}\n' \
    "$(printf '%s\n' "$@" | jq -R . | jq -s -c .)" \
    "$(printf '%s' "$stdin" | jq -Rs -c .)" \
    "$(basename "$0")")

coproc sock { socat - "UNIX-CONNECT:$SOCK"; }

printf '%s\n' "$request" >&"${sock[1]}"

while read -r line <&"${sock[0]}"; do
    type=$(printf '%s' "$line" | jq -r '.type // empty')
    case "$type" in
        data)
            printf '%s' "$line" | jq -j '.text // empty'
            ;;
        prompt)
            printf '%s' "$line" | jq -j '.text // empty' >&2
            IFS= read -r -s answer < /dev/tty
            printf '%s\n' "$answer" >&"${sock[1]}"
            ;;
        *)
            break
            ;;
    esac
done
